# Firebase Configuration (Web - Vite)
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=nk-network-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Google Gemini API
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ========== MOBILE APP (Expo) ==========
# Firebase Configuration (Mobile - Expo)
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=nk-network-project.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
EXPO_PUBLIC_FIREBASE_APP_ID=your_app_id

# Gemini API (Mobile)
EXPO_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# Google Sign-In OAuth (Get from Google Cloud Console)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_web_client_id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your_ios_client_id.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your_android_client_id.apps.googleusercontent.com

# ========== BACKEND (FastAPI) ==========
# Security - JWT (REQUIRED for production)
JWT_SECRET_KEY=your_super_secret_jwt_key_minimum_32_characters
JWT_ALGORITHM=HS256
JWT_EXPIRY_MINUTES=1440

# Security - Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Email / SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_EMAIL=your_email@gmail.com

# Gemini AI (Backend)
GEMINI_API_KEY=your_gemini_api_key_here

# Redis Cache
REDIS_URL=redis://localhost:6379
USE_REDIS=true

# CORS Configuration
CORS_ORIGINS=http://localhost:8081,http://localhost:5173
CORS_ALLOW_ALL=false

# Debug Mode (set to false in production)
DEBUG=true
