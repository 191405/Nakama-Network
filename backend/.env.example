# Nakama Network Backend Environment Variables
# Copy this file to .env and fill in your values

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Jikan API (anime data) - No API key needed
JIKAN_BASE_URL=https://api.jikan.moe/v4

# Google Gemini AI - Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Redis Cache (optional)
REDIS_URL=redis://localhost:6379

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,http://localhost:5173

# IONOS SFTP Storage (for video hosting)
SFTP_HOST=your_sftp_host_here
SFTP_PORT=22
SFTP_USERNAME=your_username_here
SFTP_PASSWORD=your_password_here
SFTP_BASE_PATH=/videos
SFTP_PUBLIC_URL=https://your-domain.com

# Backblaze B2 / AWS S3 (alternative storage)
B2_ENDPOINT_URL=
B2_ACCESS_KEY=
B2_SECRET_KEY=
B2_BUCKET_NAME=nk-network-videos
CDN_BASE_URL=

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_EMAIL=your_email@gmail.com
